# EMAIL_HOST=smtp.tu-proveedor.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=usuario
# EMAIL_HOST_PASSWORD=contraseña
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=no-reply@tu-dominio.com
