# Variables de entorno para desarrollo. Copiar a .env y ajustar.
SECRET_KEY=cambia-esta-clave-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://cadaver:cadaver@localhost:5432/cadaver_exquisito

# Email. En desarrollo se usa la consola (el código de login sale en la terminal).
# Para envío real, descomentar y completar:
